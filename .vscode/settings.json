  "cmake.sourceDirectory": "${workspaceFolder}/core",
  "cmake.configureOnOpen": true,
  "cmake.buildDirectory": "${workspaceFolder}/.build",
  "files.associations": {
    "Makevars.*": "makefile",
    "Makefile.*": "makefile",
    "*.rmd": "markdown",
    "Makefile.win": "makefile",
    "Makevars": "makefile",
    "Makevars.win": "makefile",
    "dense": "cpp",
