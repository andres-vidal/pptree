CXX_STD = CXX17

PKG_LIBS = $(SHLIB_OPENMP_CXXFLAGS) @DARWIN_OPENMP_LIBS@ -L"../inst/lib" -lppforest2-core
PKG_CPPFLAGS = -I"../inst/include" -I"core/include" -I"core/src" -DNDEBUG -DEIGEN_NO_DEBUG -DEIGEN_DONT_PARALLELIZE -DEIGEN_PERMANENTLY_DISABLE_STUPID_WARNINGS
PKG_CXXFLAGS = $(SHLIB_OPENMP_CXXFLAGS) @DARWIN_OPENMP_CXXFLAGS@ @COMPILER_FLAGS@
